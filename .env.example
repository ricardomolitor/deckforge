# ─── Cockpit BR MCP Server (via HTTP JSON-RPC 2.0) ──────────────────
# Usa o servidor MCP do Cockpit para acessar a LLM (Azure OpenAI / GPT).
# O custo da LLM é direcionado para a subscription do Cockpit.

COCKPIT_MCP_URL=https://mcp-agent.br.avanade.ai/mcp
COCKPIT_MCP_API_KEY=your-mcp-api-key
COCKPIT_API_KEY=your-cockpit-api-key
COCKPIT_LICENSE_ID=your-license-id
COCKPIT_NAMESPACE_ID=your-namespace-id
COCKPIT_UTILITY_AGENT_ID=your-utility-agent-id

# ─── Azure AD / Microsoft Entra ID (OAuth 2.0) ──────────────
# Registre um App Registration no Azure Portal:
# 1. Portal Azure → Microsoft Entra ID → App registrations → New
# 2. Redirect URI: http://localhost:3002/api/auth/callback/azure-ad
# 3. Copie Client ID, Client Secret e Tenant ID abaixo

AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# Auth
NEXTAUTH_SECRET=your-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3002

# App
NEXT_PUBLIC_APP_NAME=DeckForge
NEXT_PUBLIC_APP_URL=http://localhost:3002
